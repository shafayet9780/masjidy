# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Firebase (for FCM push notifications)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Upstash Redis (REST — use in Supabase Edge Function secrets for submit-time rate limits)
# Upstash dashboard → Redis → REST API → copy URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Aliases also read by submit-time (legacy / non-REST naming)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Upstash QStash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Twilio (Phase 1.5 — Admin Quick-Update)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Maps (Phase 1.5 only)
# GOOGLE_MAPS_API_KEY=
